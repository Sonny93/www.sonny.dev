{
	"name": "portfolio",
	"version": "3.0.3",
	"private": true,
	"license": "UNLICENSED",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "oxlint .",
		"lint:fix": "oxlint . --fix --fix-suggestions --fix-dangerously",
		"format": "pnpm lint:fix; oxfmt .",
		"format:check": "oxfmt . --check",
		"typecheck": "tsc --noEmit",
		"check": "pnpm run lint && pnpm run format:check && pnpm run typecheck",
		"knip": "knip",
		"release": "release-it --only-version",
		"screenshots:install-browser": "playwright install --with-deps chromium",
		"screenshots:generate": "node scripts/generate-project-screenshots.ts"
	},
	"dependencies": {
		"clsx": "^2.1.1"
	},
	"devDependencies": {
		"@astrojs/sitemap": "^3.7.3",
		"@minimalstuff/tooling": "^0.6.0",
		"@release-it/conventional-changelog": "^11.0.1",
		"@types/node": "^26.1.1",
		"@unocss/astro": "^66.7.5",
		"@unocss/preset-web-fonts": "^66.7.5",
		"astro": "^7.0.7",
		"knip": "^6.25.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"playwright": "^1.61.1",
		"release-it": "^20.2.1",
		"sharp": "^0.35.3",
		"typescript": "~6.0.3",
		"unocss": "^66.7.5"
	},
	"volta": {
		"node": "24.14.1"
	},
	"pnpm": {
		"overrides": {
			"@types/node": "24"
		}
	}
}
