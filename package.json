{
	"name": "portfolio",
	"version": "0.0.0",
	"private": true,
	"license": "UNLICENSED",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "oxlint .",
		"lint:fix": "oxlint . --fix --fix-suggestions --fix-dangerously",
		"format": "pnpm lint:fix; oxfmt .",
		"format:check": "oxfmt . --check",
		"typecheck": "tsc --noEmit",
		"check": "pnpm run lint && pnpm run format:check && pnpm run typecheck",
		"screenshots:install-browser": "playwright install --with-deps chromium",
		"screenshots:generate": "node scripts/generate-project-screenshots.ts"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"three": "^0.184.0"
	},
	"devDependencies": {
		"@astrojs/sitemap": "^3.7.3",
		"@minimalstuff/tooling": "^0.6.0",
		"@types/node": "^24.10.0",
		"@types/three": "^0.184.0",
		"@unocss/astro": "^66.7.4",
		"@unocss/preset-typography": "^66.6.8",
		"@unocss/preset-web-fonts": "^66.6.7",
		"astro": "^7.0.4",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"oxlint-tsgolint": "^0.24.0",
		"playwright": "^1.61.1",
		"release-it": "^19.2.4",
		"sharp": "^0.35.3",
		"typescript": "~6.0.2",
		"unocss": "^66.6.7"
	},
	"volta": {
		"node": "24.14.1"
	},
	"pnpm": {
		"overrides": {
			"@types/node": "24"
		}
	}
}
