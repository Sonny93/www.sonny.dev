---
import type { CollectionEntry } from 'astro:content';

import { ROUTES } from '../../constants/routes';
import { localizedUrl } from '../../lib/localized_url';
import { getTagColorClasses } from '../../lib/tag_colors';
import { formatPublishedDate } from '../../lib/format_date';
import { resolveLocale, useTranslations } from '../../i18n/ui';
import { estimateReadingTimeMinutes } from '../../lib/reading_time';

type Props = {
	post: CollectionEntry<'posts'>;
};

const { post } = Astro.props;

const locale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(locale);
const readTimeLabel = translate('post.readTimeUnit');
const postUrl = localizedUrl(locale, ROUTES.post(post.data.urlSlug));
const publishedAtLabel = formatPublishedDate(post.data.publishedAt, locale);
const estimatedReadTime = estimateReadingTimeMinutes(post.body ?? '');
---

<li>
	<a
		href={postUrl}
		class="group relative block rounded-lg border border-gray-700 bg-gray-800/70 p-5 shadow-sm transition duration-150 ease-out hover:rounded-none hover:border-sky-500/35 hover:shadow-md focus-visible:rounded-none"
	>
		<div
			class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 group-hover:opacity-70 group-focus-visible:opacity-70"
			aria-hidden="true"
		>
			<span class="hud-corner hud-corner--tl"></span>
			<span class="hud-corner hud-corner--tr"></span>
			<span class="hud-corner hud-corner--bl"></span>
			<span class="hud-corner hud-corner--br"></span>
		</div>

		<div class="flex flex-wrap items-baseline justify-between gap-2 gap-y-1">
			<h3
				class="text-lg text-sky-300 transition-colors group-hover:text-sky-200"
			>
				{post.data.title}
			</h3>
			<time
				class="shrink-0 text-xs tabular-nums text-gray-300"
				datetime={post.data.publishedAt.toISOString()}
			>
				{publishedAtLabel}
			</time>
		</div>
		<p class="text-xs text-gray-300">
			{estimatedReadTime} {readTimeLabel}
		</p>
		<p class="mt-2 line-clamp-2 text-left text-sm leading-relaxed text-gray-300">
			{post.data.description}
		</p>
		{
			post.data.tags.length > 0 && (
				<ul class="mt-3 flex list-none flex-wrap gap-2">
					{post.data.tags.map((tag) => (
						<li
							class={`rounded-md px-2 py-0.5 text-xs font-medium capitalize ${getTagColorClasses(tag)}`}
						>
							{tag}
						</li>
					))}
				</ul>
			)
		}
	</a>
</li>
