---
import { switchedLocaleUrl } from '../lib/localized_url';
import { LOCALES, resolveLocale, useTranslations, type Locale } from '../i18n/ui';

type Props = {
	class?: string;
};

const { class: className = '' } = Astro.props;

const LOCALE_LABELS: Readonly<Record<Locale, string>> = {
	en: 'EN',
	fr: 'FR',
};

const LOCALE_FLAG_CLASSES: Readonly<Record<Locale, string>> = {
	en: 'i-twemoji:flag-united-kingdom',
	fr: 'i-twemoji:flag-france',
};

const LOCALE_ARIA_LABEL_KEYS = {
	en: 'locale.switchToEnglish',
	fr: 'locale.switchToFrench',
} as const;

const activeLocale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(activeLocale);

const localeLinks = LOCALES.map((locale) => ({
	label: LOCALE_LABELS[locale],
	flagClass: LOCALE_FLAG_CLASSES[locale],
	href: switchedLocaleUrl(locale, Astro.url.pathname),
	isActive: locale === activeLocale,
	ariaLabel: translate(LOCALE_ARIA_LABEL_KEYS[locale]),
}));
---

<div
	class={`flex items-center gap-1 rounded-lg border border-sky-500/20 bg-slate-900/60 p-1 ${className}`}
>
	{
		localeLinks.map((localeLink) => (
			<a
				href={localeLink.href}
				data-locale={localeLink.label.toLowerCase()}
				aria-current={localeLink.isActive ? 'true' : undefined}
				aria-label={localeLink.ariaLabel}
				class="flex items-center justify-center rounded-md p-1.5 opacity-70 transition-all duration-200 hover:opacity-100 aria-[current=true]:bg-sky-500/20 aria-[current=true]:opacity-100 aria-[current=true]:shadow-sm"
			>
				<span class={`${localeLink.flagClass} size-5`} aria-hidden="true" />
			</a>
		))
	}
</div>

<script>
	document
		.querySelectorAll<HTMLAnchorElement>('a[data-locale]')
		.forEach((link) => {
			link.addEventListener('click', () => {
				const locale = link.dataset.locale;
				if (locale !== undefined)
					localStorage.setItem('preferred-locale', locale);
			});
		});
</script>
