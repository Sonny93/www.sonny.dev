---
import { ROUTES } from '../../constants/routes';
import LocaleSwitcher from '../locale_switcher.astro';
import NavigationLinks from './navigation_links.astro';
import { localizedUrl } from '../../lib/localized_url';
import { isRouteActive } from '../../lib/is_route_active';
import { resolveLocale, useTranslations } from '../../i18n/ui';

const locale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(locale);
const homeUrl = localizedUrl(locale, ROUTES.home);
const currentPathname = Astro.url.pathname;

const mobileNavigationLinks = [
	{ key: 'navigation.home' as const, path: ROUTES.home },
	{ key: 'navigation.blog' as const, path: ROUTES.blog },
	{ key: 'navigation.projects' as const, path: ROUTES.projects },
].map((item) => {
	const href = localizedUrl(locale, item.path);
	return {
		key: item.key,
		href,
		isActive: isRouteActive(item.path, href, currentPathname),
	};
});
---

<nav
	id="site-nav"
	data-headroom
	data-pinned="true"
	class="hud-bar sticky top-2 z-[99] flex w-full items-center justify-between gap-2 rounded-b-xl border border-sky-500/20 bg-slate-900/70 px-4 py-2 backdrop-blur-xl transition-[transform,opacity] duration-300 ease-out translate-y-0 opacity-100 data-[pinned=false]:-translate-y-2 data-[pinned=false]:opacity-0"
>
	<span class="hud-corner hud-corner--tl" aria-hidden="true"></span>
	<span class="hud-corner hud-corner--tr" aria-hidden="true"></span>

	<a
		href={homeUrl}
		class="flex items-center gap-2 rounded-md px-1.5 py-1 text-sm font-black tracking-[0.2em] text-white"
	>
		<span class="hud-brand-dot" aria-hidden="true"></span>
		Sonny
	</a>

	<div class="hidden items-center gap-2 sm:flex">
		<NavigationLinks />
		<span class="h-5 w-px bg-sky-500/20" aria-hidden="true"></span>
		<LocaleSwitcher />
	</div>

	<button
		type="button"
		id="nav-menu-toggle"
		aria-expanded="false"
		aria-controls="nav-menu-panel"
		class="menu-toggle relative flex size-9 flex-col items-center justify-center gap-1.5 rounded-md border border-sky-500/20 sm:hidden"
	>
		<span class="sr-only">{translate('navigation.openMenu')}</span>
		<span class="menu-toggle-bar block h-px w-5 bg-gray-200"></span>
		<span class="menu-toggle-bar block h-px w-5 bg-gray-200"></span>
	</button>
</nav>

<div
	id="nav-menu-panel"
	inert
	class="nav-menu-panel fixed inset-x-4 top-[calc(env(safe-area-inset-top,0px)+4.5rem)] z-[98] flex flex-col gap-4 rounded-xl border border-sky-500/20 bg-slate-900/95 p-5 opacity-0 backdrop-blur-xl transition-[opacity,transform] duration-200 ease-out -translate-y-2 sm:hidden"
>
	<ul class="flex flex-col gap-1 text-base">
		{
			mobileNavigationLinks.map((item) => (
				<li>
					<a
						href={item.href}
						aria-current={item.isActive ? 'page' : undefined}
						class="block rounded-md px-3 py-2.5 font-semibold uppercase tracking-[0.14em] text-gray-200 hover:bg-sky-500/10 hover:text-white aria-[current=page]:bg-sky-500/15 aria-[current=page]:text-white"
					>
						{translate(item.key)}
					</a>
				</li>
			))
		}
	</ul>
	<LocaleSwitcher class="self-start" />
</div>

<script src="../../scripts/headroom.ts"></script>
<script src="../../scripts/nav_menu.ts"></script>

<style>
	.hud-corner {
		position: absolute;
		width: 10px;
		height: 10px;
		pointer-events: none;
		opacity: 0.7;
	}

	.hud-corner--tl {
		top: -1px;
		left: -1px;
		border-top: 1px solid rgb(56 189 248 / 0.9);
		border-left: 1px solid rgb(56 189 248 / 0.9);
		border-top-left-radius: 4px;
	}

	.hud-corner--tr {
		top: -1px;
		right: -1px;
		border-top: 1px solid rgb(56 189 248 / 0.9);
		border-right: 1px solid rgb(56 189 248 / 0.9);
		border-top-right-radius: 4px;
	}

	.hud-brand-dot {
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #38bdf8;
		box-shadow: 0 0 8px 2px rgb(56 189 248 / 0.8);
		animation: hud-pulse 2.4s ease-in-out infinite;
	}

	@keyframes hud-pulse {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.4;
		}
	}

	.menu-toggle-bar {
		transition: transform 0.2s ease;
	}

	#nav-menu-toggle[aria-expanded='true'] .menu-toggle-bar:first-child {
		transform: translateY(3.5px) rotate(45deg);
	}

	#nav-menu-toggle[aria-expanded='true'] .menu-toggle-bar:last-child {
		transform: translateY(-3.5px) rotate(-45deg);
	}

	.nav-menu-panel[data-open='true'] {
		opacity: 1;
		transform: translateY(0);
	}
</style>
