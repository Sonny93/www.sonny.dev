---
import { localizedUrl } from '../../lib/localized_url';
import { isRouteActive } from '../../lib/is_route_active';
import { ROUTES, type RoutePath } from '../../constants/routes';
import {
	resolveLocale,
	useTranslations,
	type UiStringKey,
} from '../../i18n/ui';

type NavigationTarget = {
	labelKey: UiStringKey;
	routePath: RoutePath;
};

const NAVIGATION_TARGETS: readonly NavigationTarget[] = [
	{ labelKey: 'navigation.home', routePath: ROUTES.home },
	{ labelKey: 'navigation.blog', routePath: ROUTES.blog },
	{ labelKey: 'navigation.projects', routePath: ROUTES.projects },
];

const locale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(locale);
const currentPathname = Astro.url.pathname;

const navigationLinks = NAVIGATION_TARGETS.map((navigationTarget) => {
	const href = localizedUrl(locale, navigationTarget.routePath);
	return {
		label: translate(navigationTarget.labelKey),
		href,
		isActive: isRouteActive(navigationTarget.routePath, href, currentPathname),
	};
});
---

<ul class="nav-links relative flex list-none items-center gap-1 sm:gap-2">
	{
		navigationLinks.map((navigationLink) => (
			<li>
				<a
					href={navigationLink.href}
					aria-current={navigationLink.isActive ? 'page' : undefined}
					class="nav-link relative flex items-center whitespace-nowrap rounded-md px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-gray-300 transition-colors duration-150 hover:text-white aria-[current=page]:text-white"
				>
					{navigationLink.label}
				</a>
			</li>
		))
	}
	<span
		id="nav-active-indicator"
		class="pointer-events-none absolute -bottom-1.5 left-0 h-1 w-1 -translate-x-1/2 rounded-full bg-sky-400 opacity-0 shadow-[0_0_6px_1px_rgba(56,189,248,0.9)]"
		aria-hidden="true"
		transition:persist="nav-active-indicator"
	/>
</ul>

<script src="../../scripts/nav_indicator.ts"></script>

<style>
	.nav-link::after {
		content: '';
		position: absolute;
		left: 10%;
		right: 10%;
		bottom: 2px;
		height: 1px;
		background: rgb(56 189 248 / 0.7);
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.2s ease;
	}

	.nav-link:hover::after,
	.nav-link:focus-visible::after {
		transform: scaleX(1);
	}

	#nav-active-indicator {
		transition:
			left 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			opacity 0.2s ease;
	}
</style>
