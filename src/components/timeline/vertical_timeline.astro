---
import SectionTitle from '../section_title.astro';

export type VerticalTimelineItem = {
	id: string;
	title: string;
	titleVariant?: 'default' | 'uppercase';
	subtitle?: string;
	metaHtml: string;
	bullets?: readonly string[];
};

type Props = {
	title: string;
	items: readonly VerticalTimelineItem[];
	class?: string;
};

const { title, items, class: className = '' } = Astro.props;
---

{
	items.length > 0 && (
		<section class={className}>
			<SectionTitle title={title} />
			<ul class="relative ml-0.5 space-y-10 pl-6 sm:ml-1 sm:pl-8">
				<span
					class="pointer-events-none absolute inset-y-3.5 left-0 w-px bg-gradient-to-b from-sky-400/60 via-sky-500/20 to-transparent"
					aria-hidden="true"
				/>
				{items.map((item, itemIndex) => (
					<li class="relative">
						{itemIndex === 0 ? (
							<span
								class="hud-dot absolute right-full top-[0.5em] mr-[1.275rem] sm:mr-[1.8rem]"
								aria-hidden="true"
							/>
						) : (
							<span
								class="absolute right-full top-[0.5em] mr-[1.275rem] h-1.5 w-1.5 rounded-full bg-sky-400/50 sm:mr-[1.8rem]"
								aria-hidden="true"
							/>
						)}
						<div class="min-w-0">
							<p class="text-pretty text-[0.95rem] leading-snug text-white/95 sm:text-base">
								<span
									class={
										item.titleVariant === 'uppercase'
											? 'font-bold uppercase tracking-wide'
											: 'font-bold'
									}
								>
									{item.title}
								</span>
								{item.subtitle && (
									<span class="font-normal text-white/85">
										{' '}
										{item.subtitle}
									</span>
								)}
							</p>
							<div
								class="mt-1.5 text-pretty text-sm leading-relaxed text-white/65"
								set:html={item.metaHtml}
							/>
							{item.bullets && item.bullets.length > 0 && (
								<ul class="mt-3 list-none space-y-2 pl-0.5">
									{item.bullets.map((bulletLine) => (
										<li class="flex gap-2.5 text-sm leading-relaxed text-white/75">
											<span
												class="mt-2 size-1.5 shrink-0 rounded-full border border-current opacity-70"
												aria-hidden="true"
											/>
											<span>{bulletLine}</span>
										</li>
									))}
								</ul>
							)}
						</div>
					</li>
				))}
			</ul>
		</section>
	)
}
