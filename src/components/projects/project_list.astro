---
import type { Locale } from '../../i18n/ui';
import ProjectItem from './project_item.astro';
import type { Project } from '../../data/projects';

type Props = {
	projects: readonly Project[];
	locale: Locale;
};

const { projects, locale } = Astro.props;
---

<ul class="grid list-none gap-6 sm:grid-cols-2">
	{projects.map((project) => <ProjectItem project={project} locale={locale} />)}
</ul>
