---
import '../styles/global.css';

import { ClientRouter } from 'astro:transitions';

import { DEFAULT_LOCALE, LOCALES, resolveLocale, useTranslations } from '../i18n/ui';

export type OpenGraphType = 'website' | 'article';

type Props = {
	title?: string;
	description?: string;
	openGraphType?: OpenGraphType;
	image?: string;
	imageAlt?: string;
};

const DEFAULT_TITLE = 'App';
const SITE_NAME = 'Sonny';
const OG_IMAGE_WIDTH = 1280;
const OG_IMAGE_HEIGHT = 720;
const OG_LOCALE_BY_LOCALE: Record<(typeof LOCALES)[number], string> = {
	en: 'en_US',
	fr: 'fr_FR',
};

const {
	title = DEFAULT_TITLE,
	description,
	openGraphType = 'website',
	image,
	imageAlt = title,
} = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(locale);
const openGraphUrl =
	Astro.site === undefined
		? undefined
		: new URL(Astro.url.pathname, Astro.site).toString();
const openGraphImagePath = image ?? `/og/default-${locale}.png`;
const openGraphImageUrl =
	Astro.site === undefined
		? openGraphImagePath
		: new URL(openGraphImagePath, Astro.site).toString();
const openGraphLocale = OG_LOCALE_BY_LOCALE[locale];
const openGraphAlternateLocales = LOCALES.filter(
	(alternateLocale) => alternateLocale !== locale
).map((alternateLocale) => OG_LOCALE_BY_LOCALE[alternateLocale]);

const LOCALIZED_PATH_PATTERN = new RegExp(`^/(${LOCALES.join('|')})(/.*)?$`);
const localizedPathMatch = Astro.url.pathname.match(LOCALIZED_PATH_PATTERN);
const alternatePathSuffix = localizedPathMatch?.[2] ?? '/';
const alternateLinks =
	Astro.site === undefined || localizedPathMatch === null
		? []
		: LOCALES.map((alternateLocale) => ({
				hreflang: alternateLocale,
				href: new URL(
					`/${alternateLocale}${alternatePathSuffix}`,
					Astro.site
				).toString(),
			}));
const defaultAlternateUrl =
	Astro.site === undefined || localizedPathMatch === null
		? undefined
		: new URL(`/${DEFAULT_LOCALE}${alternatePathSuffix}`, Astro.site).toString();
---

<html lang={locale} class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<title>{title}</title>
		{
			description !== undefined && (
				<meta name="description" content={description} />
			)
		}
		{openGraphUrl !== undefined && <link rel="canonical" href={openGraphUrl} />}

		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={title} />
		{
			description !== undefined && (
				<meta property="og:description" content={description} />
			)
		}
		<meta property="og:type" content={openGraphType} />
		{
			openGraphUrl !== undefined && (
				<meta property="og:url" content={openGraphUrl} />
			)
		}
		<meta property="og:locale" content={openGraphLocale} />
		{openGraphAlternateLocales.map((alternateLocale) => (
			<meta property="og:locale:alternate" content={alternateLocale} />
		))}
		<meta property="og:image" content={openGraphImageUrl} />
		<meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
		<meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
		<meta property="og:image:alt" content={imageAlt} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		{
			description !== undefined && (
				<meta name="twitter:description" content={description} />
			)
		}
		<meta name="twitter:image" content={openGraphImageUrl} />
		<meta name="twitter:image:alt" content={imageAlt} />

		{alternateLinks.map(({ hreflang, href }) => (
			<link rel="alternate" hreflang={hreflang} href={href} />
		))}
		{
			defaultAlternateUrl !== undefined && (
				<link rel="alternate" hreflang="x-default" href={defaultAlternateUrl} />
			)
		}

		<ClientRouter />
	</head>

	<body>
		<a href="#main-content" class="skip-link">
			{translate('navigation.skipToContent')}
		</a>
		<canvas
			id="space-background"
			style="position: fixed; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"
			aria-hidden="true"
			transition:persist="space-background"></canvas>
		<slot />

		<script src="../scripts/space_background.ts"></script>
		<script src="../scripts/headroom.ts"></script>
	</body>
</html>

<style>
	.skip-link {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
	}

	.skip-link:focus {
		z-index: 999;
		width: auto;
		height: auto;
		overflow: visible;
		clip: auto;
		top: 1rem;
		left: 1rem;
		padding: 0.5rem 1rem;
		border-radius: 0.375rem;
		background-color: #38bdf8;
		color: #020617;
		font-size: 0.875rem;
		font-weight: 600;
		white-space: normal;
	}
</style>
