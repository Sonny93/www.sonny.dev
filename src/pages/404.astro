---
import DefaultLayout from '../layouts/default_layout.astro';
import { DEFAULT_LOCALE, useTranslations } from '../i18n/ui';

const translate = useTranslations(DEFAULT_LOCALE);
---

<DefaultLayout title={translate('notFound.title')}>
	<div class="flex flex-col items-center gap-3 py-16 text-center">
		<h1 class="text-2xl font-bold text-white sm:text-3xl">
			{translate('notFound.title')}
		</h1>
		<p class="text-gray-300">{translate('notFound.description')}</p>
	</div>
</DefaultLayout>
