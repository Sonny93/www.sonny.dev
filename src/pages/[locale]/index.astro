---
import { ROUTES } from '../../constants/routes';
import { escapeHtml } from '../../lib/escape_html';
import { getPublishedPosts } from '../../lib/posts';
import { formatPeriod } from '../../lib/format_period';
import { localizedUrl } from '../../lib/localized_url';
import PostList from '../../components/posts/post_list.astro';
import DefaultLayout from '../../layouts/default_layout.astro';
import SectionTitle from '../../components/section_title.astro';
import { experiences, type Experience } from '../../data/experiences';
import VerticalTimeline from '../../components/timeline/vertical_timeline.astro';
import {
	LOCALES,
	resolveLocale,
	useTranslations,
	type UiStringKey,
} from '../../i18n/ui';

export function getStaticPaths() {
	return LOCALES.map((locale) => ({ params: { locale } }));
}

const LATEST_POSTS_COUNT = 3;

const SKILL_KEYS: readonly UiStringKey[] = [
	'home.skillFullStack',
	'home.skillAutomation',
	'home.skillTooling',
];

function buildExperienceMetaHtml(experience: Experience): string {
	const periodLabel = formatPeriod(
		experience.beginningDate,
		experience.endDate
	);
	const companyLabel = escapeHtml(experience.company);
	const cityLabel = escapeHtml(experience.city);
	return `${periodLabel} <span>(<span class="font-semibold text-white/95">${companyLabel}</span> – ${cityLabel})</span>`;
}

const locale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(locale);

const latestPosts = (await getPublishedPosts()).slice(0, LATEST_POSTS_COUNT);
const blogUrl = localizedUrl(locale, ROUTES.blog);
const skillLabels = SKILL_KEYS.map(translate);

const experienceTimelineItems = experiences.map(
	(experience, experienceIndex) => ({
		id: `experience-${experienceIndex}-${experience.beginningDate}`,
		title: experience.title,
		titleVariant: 'uppercase' as const,
		metaHtml: buildExperienceMetaHtml(experience),
		bullets: experience.description,
	})
);
---

<DefaultLayout
	title={translate('home.pageTitle')}
	description={translate('home.introduction')}
>
	<section
		class="relative overflow-hidden rounded-3xl border border-slate-700 bg-linear-to-br from-slate-900 via-slate-900 to-slate-800 px-6 py-10 sm:px-10 sm:py-12"
	>
		<div
			class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-sky-500/15 blur-3xl"
		>
		</div>
		<div
			class="pointer-events-none absolute -bottom-24 -left-20 h-72 w-72 rounded-full bg-cyan-500/15 blur-3xl"
		>
		</div>

		<div class="relative">
			<div class="space-y-6">
				<span
					class="inline-flex w-fit items-center rounded-full border border-slate-600 bg-slate-900/75 px-4 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-sky-300 backdrop-blur"
				>
					{translate('home.availability')}
				</span>

				<h1
					class="max-w-3xl text-balance text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl"
				>
					{translate('home.headline')}
				</h1>

				<p
					class="max-w-2xl text-pretty text-base leading-relaxed text-slate-300 sm:text-lg"
				>
					{translate('home.introduction')}
				</p>

				<ul
					class="grid gap-2.5 text-sm text-slate-300 sm:grid-cols-2 sm:text-base"
				>
					{
						skillLabels.map((skillLabel) => (
							<li class="flex items-center gap-2 rounded-xl bg-slate-800/70 px-3 py-2 backdrop-blur">
								<span
									class="h-2 w-2 rounded-full bg-sky-400"
									aria-hidden="true"
								/>
								{skillLabel}
							</li>
						))
					}
				</ul>

				<a
					href={blogUrl}
					class="inline-flex items-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-200"
				>
					{translate('home.readLatestPosts')}
				</a>
			</div>
		</div>
	</section>

	{
		latestPosts.length > 0 && (
			<section class="flex w-full flex-col gap-4">
				<SectionTitle title={translate('home.latestArticles')} />
				<a href={blogUrl} class="self-end text-sm text-gray-400">
					{translate('home.viewAllArticles')} &rarr;
				</a>
				<PostList posts={latestPosts} />
			</section>
		)
	}

	<VerticalTimeline
		title={translate('home.experiences')}
		items={experienceTimelineItems}
	/>
</DefaultLayout>
