---
import { ROUTES } from '../../constants/routes';
import { formations } from '../../data/formations';
import { getPublishedPosts } from '../../lib/posts';
import { experiences } from '../../data/experiences';
import { localizedUrl } from '../../lib/localized_url';
import PostList from '../../components/posts/post_list.astro';
import DefaultLayout from '../../layouts/default_layout.astro';
import SectionTitle from '../../components/section_title.astro';
import VerticalTimeline from '../../components/timeline/vertical_timeline.astro';
import {
	LOCALES,
	resolveLocale,
	useTranslations,
	type UiStringKey,
} from '../../i18n/ui';
import {
	buildExperienceTimelineItems,
	buildFormationTimelineItems,
} from '../../lib/timeline_items';

export function getStaticPaths() {
	return LOCALES.map((locale) => ({ params: { locale } }));
}

const LATEST_POSTS_COUNT = 3;
const HOME_EXPERIENCES_COUNT = 2;
const HOME_FORMATIONS_COUNT = 2;

const SKILL_KEYS: readonly UiStringKey[] = [
	'home.skillFullStack',
	'home.skillAutomation',
	'home.skillHomelab',
];

const locale = resolveLocale(Astro.currentLocale);
const translate = useTranslations(locale);

const latestPosts = (await getPublishedPosts(locale)).slice(
	0,
	LATEST_POSTS_COUNT
);
const blogUrl = localizedUrl(locale, ROUTES.blog);
const backgroundUrl = localizedUrl(locale, ROUTES.background);
const skillLabels = SKILL_KEYS.map(translate);

const experienceTimelineItems = buildExperienceTimelineItems(
	experiences.slice(0, HOME_EXPERIENCES_COUNT)
);
const formationTimelineItems = buildFormationTimelineItems(
	formations.slice(0, HOME_FORMATIONS_COUNT)
);
---

<DefaultLayout
	title={translate('home.pageTitle')}
	description={translate('home.introduction')}
>
	<section class="relative overflow-hidden px-2 py-16 sm:py-24">
		<span class="hud-corner hud-corner--tl opacity-40" aria-hidden="true"
		></span>
		<span class="hud-corner hud-corner--tr opacity-40" aria-hidden="true"
		></span>
		<span class="hud-corner hud-corner--bl opacity-40" aria-hidden="true"
		></span>
		<span class="hud-corner hud-corner--br opacity-40" aria-hidden="true"
		></span>

		<div
			class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_70%_at_15%_25%,rgba(3,11,26,0.65),transparent_70%)]"
			aria-hidden="true"
		>
		</div>

		<div class="relative space-y-6">
			<span
				class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-600 bg-slate-900/75 px-4 py-1 text-xs uppercase tracking-[0.14em] text-sky-300 backdrop-blur"
			>
				<span class="hud-dot" aria-hidden="true"></span>
				{translate('home.availability')}
			</span>

			<h1
				class="max-w-3xl text-balance text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl"
			>
				{translate('home.headline')}
			</h1>

			<p
				class="max-w-2xl text-pretty text-base leading-relaxed text-slate-300 sm:text-lg"
			>
				{translate('home.introduction')}
			</p>

			<ul
				class="grid gap-2.5 text-sm text-slate-300 sm:grid-cols-2 sm:text-base"
			>
				{
					skillLabels.map((skillLabel) => (
						<li class="flex items-center gap-2 rounded-xl bg-slate-800/70 px-3 py-2 backdrop-blur">
							<span class="h-2 w-2 rounded-full bg-sky-400" aria-hidden="true" />
							{skillLabel}
						</li>
					))
				}
			</ul>

			<a
				href={blogUrl}
				class="inline-flex items-center rounded-xl bg-white px-5 py-3 text-sm text-slate-900 transition hover:bg-slate-200"
			>
				{translate('home.readLatestPosts')}
			</a>
		</div>
	</section>

	{
		latestPosts.length > 0 && (
			<section class="flex w-full flex-col gap-4">
				<SectionTitle title={translate('home.latestArticles')} />
				<a href={blogUrl} class="self-end text-sm text-gray-400">
					{translate('home.viewAllArticles')} &rarr;
				</a>
				<PostList posts={latestPosts} />
			</section>
		)
	}

		<div class="flex w-full flex-col gap-10">
			<a
				href={backgroundUrl}
				class="self-end text-sm text-gray-400 hover:text-white"
			>
				{translate('home.viewFullBackground')} &rarr;
			</a>
			<VerticalTimeline
				title={translate('home.experiences')}
				items={experienceTimelineItems}
			/>
			<VerticalTimeline
				title={translate('home.formations')}
				items={formationTimelineItems}
			/>
		</div>
</DefaultLayout>
